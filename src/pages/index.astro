---
// src/pages/index.astro
// bety-story.github.io — Happy Birthday Ibu Bos Bety 🌸
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Happy Birthday Anastasia Bety 🌸" />
  <title>🎂🌸 Happy Birthday Ibu Bos 🌸🎂</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌸</text></svg>" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>

  <div id="petals"></div>
  <div id="confetti"></div>

  <!-- Hero -->
  <div class="hero">
    <div class="badge">🎀 24 April 2026 🎀</div>
    <h1>Happy Birthday</h1>
    <h2>Ibu Bos! 🌸</h2>
    <p class="subtitle">Semoga Bahagia Selalu!</p>
  </div>

  <!-- Cake -->
  <div class="cake-section">
    <div class="cake-float">
      <div class="candles-row" id="candlesRow"></div>
      <div class="cake-emoji">🎂</div>
    </div>
    <button id="blowBtn" onclick="blowCandles()">🎂 Tiup lilinnya, Ibu Bos!</button>
  </div>

  <!-- Second Brain Release -->
  <div class="release-wrap">
    <div class="release-card">
      <div class="release-icon">🧠</div>
      <h3 class="release-title">Hadiah Spesial: Second Brain dan Gem</h3>
      <p class="release-sub">Ini bukan sekadar diary.</p>
      <p class="release-body">
        Hari ini, bersamaan dengan ulang tahunmu, Pak Bos dengan resmi merilis
        <strong>Obsidian Vault</strong> — <strong>The Second Brain</strong>
		yang dibangun khusus untukmu.
        Tempat semua pikiran, pekerjaan, dan ceritamu tersimpan rapi dalam satu tempat.
      </p>
      <p class="release-body">
        Dilengkapi dengan <strong>Gem</strong> 🤖 — asisten pribadimu yang siap membantu
        dari notulensi rapat sampai bikin slide presentasi, kapanpun kamu butuh.
      </p>
      <div class="release-badge-row">
        <span class="release-badge">📦 Release: 2026.04.24</span>
        <span class="release-badge">❤️ Khusus untuk Ibu Bos</span>
      </div>
    </div>
  </div>

  <!-- Message carousel -->
  <div class="msg-wrap">
    <div class="msg-card">
      <div class="msg-inner" id="msgInner">
        <p class="msg-from" id="msgFrom"></p>
        <p class="msg-text"  id="msgText"></p>
      </div>
      <div class="dots" id="dots"></div>
    </div>
  </div>

  <!-- Wishes -->
  <div class="wishes-wrap">
    <p class="wishes-title">Doa &amp; harapan untuk Ibu Bos ✨</p>
    <div class="wishes-grid" id="wishesGrid"></div>
  </div>

  <!-- Special note -->
  <div class="note-wrap">
    <div class="note-card">
      <div class="note-icon">💌</div>
      <p class="note-quote">
        "Semoga dengan Second Brain (Diary) dan Gem Ibu Bos tambah lancar jaya kerjanya"
      </p>
      <div class="note-from">💙 Melayani Ibu Bos dengan penuh cinta: Pak Bos &amp; Gem</div>
    </div>
  </div>

  <footer class="main-footer">
    <div class="footer-divider"></div>
    <p class="footer-text">
      Diary 🌸 · 24 April 2026
    </p>
    <p class="footer-credit">
      Made with <span class="heart-icon">❤️</span> by <span class="author-name">Anthonius Munthi</span>
    </p>
    <div class="footer-icons">
      <span>✨</span><span>🚀</span><span>💎</span><span>💻</span>
    </div>
  </footer>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    min-height: 100vh;
    background: linear-gradient(160deg, #fff0f8 0%, #fdf4ff 35%, #fff5f0 65%, #f0f8ff 100%);
    font-family: 'Lato', sans-serif;
    overflow-x: hidden;
    padding-bottom: 60px;
  }

  /* ── Falling petals ── */
  :global(.petal) {
    position: fixed;
    top: -40px;
    pointer-events: none;
    z-index: 0;
    animation: fall linear infinite;
  }
  @keyframes fall {
    0%   { transform: translateY(-40px) rotate(0deg);   opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: .8; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }

  @keyframes flicker {
    0%   { transform: scale(1) rotate(-3deg); }
    100% { transform: scale(1.15) rotate(3deg); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes popIn {
    0%   { transform: scale(.5); opacity: 0; }
    70%  { transform: scale(1.08); }
    100% { transform: scale(1); opacity: 1; }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }
  @keyframes shimmer {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0    rgba(219,39,119,.35); }
    50%      { box-shadow: 0 0 0 14px rgba(219,39,119,0); }
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(16px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes wishIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    padding: 52px 24px 36px;
    position: relative;
    z-index: 1;
    animation: fadeUp .8s ease both;
  }
  .badge {
    display: inline-block;
    background: linear-gradient(135deg, #DB2777, #9333EA);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 6px 20px;
    border-radius: 40px;
    margin-bottom: 20px;
    box-shadow: 0 4px 16px rgba(219,39,119,.35);
  }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    font-weight: 700;
    background: linear-gradient(135deg, #DB2777 0%, #9333EA 50%, #EC4899 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 3s linear infinite;
    margin-bottom: 10px;
    line-height: 1.2;
  }
  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: #9333EA;
    margin-bottom: 6px;
  }
  .subtitle { color: #BE185D; font-size: 15px; font-weight: 300; letter-spacing: .5px; }

  /* ── Cake ── */
  .cake-section {
    text-align: center;
    padding: 0 24px 8px;
    position: relative;
    z-index: 1;
    animation: popIn .7s .3s ease both;
  }
  .cake-float { animation: float 3s ease-in-out infinite; display: inline-block; }
  .candles-row { display: flex; justify-content: center; gap: 14px; margin-bottom: 4px; }

  :global(.candle) { display: flex; flex-direction: column; align-items: center; }
  :global(.candle .flame) {
    font-size: 18px;
    animation: flicker 1.2s ease-in-out infinite alternate;
    margin-bottom: -4px;
  }
  :global(.candle .wax) {
    width: 10px; height: 32px;
    background: linear-gradient(180deg, #FFD6E7, #FFB3D1);
    border-radius: 4px 4px 2px 2px;
    transition: box-shadow .4s;
  }
  :global(.candle.lit .wax) { box-shadow: 0 0 10px #FFB3D180; }

  .cake-emoji {
    font-size: clamp(5rem, 15vw, 7rem);
    line-height: 1;
    filter: drop-shadow(0 8px 20px rgba(219,39,119,.3));
  }

  #blowBtn {
    margin-top: 18px;
    background: linear-gradient(135deg, #DB2777, #9333EA);
    color: #fff;
    border: none;
    border-radius: 40px;
    padding: 13px 30px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Lato', sans-serif;
    letter-spacing: .5px;
    transition: transform .2s, box-shadow .2s;
    animation: pulse 2s infinite;
    box-shadow: 0 4px 20px rgba(219,39,119,.4);
  }
  #blowBtn:hover  { transform: scale(1.06); }
  #blowBtn:active { transform: scale(.97); }
  #blowBtn.blown  { background: linear-gradient(135deg, #9CA3AF, #6B7280); box-shadow: none; animation: none; }

  :global(.confetti-piece) { position: fixed; font-size: 22px; pointer-events: none; z-index: 999; }

  /* ── Message carousel ── */
  .msg-wrap {
    max-width: 520px;
    margin: 28px auto 0;
    padding: 0 20px;
    position: relative;
    z-index: 1;
    animation: fadeUp .7s .5s ease both;
  }
  .msg-card {
    background: #fff;
    border-radius: 20px;
    padding: 24px 28px;
    box-shadow: 0 4px 32px rgba(219,39,119,.12);
    border: 1.5px solid #FCE7F3;
    min-height: 130px;
    position: relative;
    overflow: hidden;
  }
  .msg-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #DB2777, #9333EA, #EC4899);
    border-radius: 20px 20px 0 0;
  }
  :global(.msg-from) { font-size: 11px; font-weight: 700; color: #9333EA; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
  :global(.msg-text) { font-size: 15px; color: #374151; line-height: 1.75; font-style: italic; }
  :global(.msg-inner) { animation: slideIn .4s ease both; }

  .dots { display: flex; gap: 6px; justify-content: center; margin-top: 16px; }
  :global(.dot) { height: 7px; width: 7px; border-radius: 4px; background: #FCE7F3; cursor: pointer; transition: all .3s; }
  :global(.dot.active) { background: #DB2777; width: 20px; }

  /* ── Wishes ── */
  .wishes-wrap { max-width: 560px; margin: 32px auto 0; padding: 0 20px; position: relative; z-index: 1; }
  .wishes-title {
    text-align: center;
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    color: #BE185D;
    font-style: italic;
    margin-bottom: 18px;
    opacity: 0;
    animation: fadeUp .6s .8s ease forwards;
  }
  .wishes-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  :global(.wish-card) {
    background: #fff;
    border-radius: 16px;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 2px 12px rgba(219,39,119,.08);
    border: 1.5px solid #FDF2F8;
    opacity: 0;
    transition: box-shadow .2s, transform .2s;
    cursor: default;
  }
  :global(.wish-card:hover) { transform: translateY(-4px) scale(1.03); box-shadow: 0 8px 24px rgba(219,39,119,.18); }
  :global(.wish-icon) { font-size: 26px; flex-shrink: 0; }
  :global(.wish-text) { font-size: 13px; color: #374151; line-height: 1.4; }

  /* ── Special note ── */
  .note-wrap {
    max-width: 520px;
    margin: 32px auto 0;
    padding: 0 20px;
    position: relative;
    z-index: 1;
    opacity: 0;
    animation: fadeUp .7s 1.4s ease forwards;
  }
  .note-card {
    background: linear-gradient(135deg, #FDF2F8, #F5F3FF);
    border-radius: 20px;
    padding: 28px;
    border: 1.5px solid #F0E0F8;
    text-align: center;
  }
  .note-icon  { font-size: 32px; margin-bottom: 14px; }
  .note-quote {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    color: #6D28D9;
    font-style: italic;
    line-height: 1.8;
    margin-bottom: 18px;
  }
  .note-from {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #DB2777, #9333EA);
    color: #fff;
    padding: 8px 22px;
    border-radius: 40px;
    font-size: 13px;
    font-weight: 700;
  }

  /* ── Release section ── */
  .release-wrap {
    max-width: 520px;
    margin: 28px auto 0;
    padding: 0 20px;
    position: relative;
    z-index: 1;
    opacity: 0;
    animation: fadeUp .7s .4s ease forwards;
  }
  .release-card {
    background: #fff;
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 4px 32px rgba(124,58,237,.1);
    border: 1.5px solid #EDE9FE;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .release-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #9333EA, #DB2777, #9333EA);
    border-radius: 20px 20px 0 0;
  }
  .release-icon { font-size: 36px; margin-bottom: 12px; }
  .release-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: #6D28D9;
    margin-bottom: 6px;
  }
  .release-sub {
    font-size: 13px;
    color: #9CA3AF;
    font-style: italic;
    margin-bottom: 16px;
  }
  .release-body {
    font-size: 14px;
    color: #374151;
    line-height: 1.75;
    margin-bottom: 12px;
  }
  .release-badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-top: 18px;
  }
  .release-badge {
    background: linear-gradient(135deg, #EDE9FE, #FCE7F3);
    color: #6D28D9;
    font-size: 12px;
    font-weight: 700;
    padding: 6px 16px;
    border-radius: 40px;
    border: 1px solid #DDD6FE;
    letter-spacing: .3px;
  }

  .main-footer {
    text-align: center;
    margin-top: 60px;
    padding: 40px 20px;
    position: relative;
    z-index: 1;
    background: linear-gradient(to top, rgba(253, 242, 248, 0.8), transparent);
  }
  .footer-divider {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, #DB2777, #9333EA);
    margin: 0 auto 24px;
    border-radius: 10px;
    opacity: 0.3;
  }
  .footer-text {
    color: #9CA3AF;
    font-size: 14px;
    letter-spacing: 1px;
    margin-bottom: 8px;
    text-transform: uppercase;
    font-weight: 700;
  }
  .footer-credit {
    color: #4B5563;
    font-size: 15px;
    font-style: italic;
    margin-bottom: 16px;
  }
  .heart-icon {
    display: inline-block;
    color: #EF4444;
    animation: heartBeat 1.5s infinite;
  }
  .author-name {
    font-weight: 700;
    color: #6D28D9;
    font-style: normal;
  }
  .footer-icons {
    display: flex;
    justify-content: center;
    gap: 15px;
    font-size: 18px;
    opacity: 0.6;
  }
  .footer-icons span {
    transition: transform 0.3s ease, opacity 0.3s ease;
    cursor: default;
  }
  .footer-icons span:hover {
    transform: scale(1.4) rotate(10deg);
    opacity: 1;
  }

  @keyframes heartBeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }
</style>

<script>
  const PETALS_DATA = Array.from({ length: 28 }, () => ({
    left:     Math.random() * 100,
    delay:    Math.random() * 8,
    duration: 6 + Math.random() * 6,
    size:     10 + Math.random() * 16,
    emoji:    ["🌸","🌷","💮","🌺","✨","💜","🩷"][Math.floor(Math.random() * 7)],
  }));

  const MESSAGES = [
    { from: "Pak Bos 💙", msg: "Mudah-mudahan Second Brain (Diary) dan Gem ini bikin Ibu Bos tambah santai kerjanya. Happy Birthday! 🎂" },
    { from: "Gem 🤖💜",   msg: "Halo Ibu Bos yang paling keren! Gem selalu ada di sini buat bantu semua kerjaan. Selamat ulang tahun — semoga hari-harimu selalu berwarna dan penuh semangat! 🌸" },
    { from: "Pak Bos 💙", msg: "Semoga tahun ini Ibu Bos makin bahagia, makin sehat! 💜" },
  ];

  const WISHES = [
    { icon: "🌸", text: "Selalu sehat & bahagia" },
    { icon: "✨", text: "Karir makin cemerlang" },
    { icon: "💜", text: "Dicintai oleh orang-orang terbaik" },
    { icon: "🎯", text: "Semua target KLA dan yang lainnya 2026 tercapai" },
    { icon: "📖", text: "Second Brain makin penuh cerita indah" },
    { icon: "🌺", text: "Semangat nggak pernah padam" },
  ];

  // Falling petals
  const petalsEl = document.getElementById('petals')!;
  PETALS_DATA.forEach(p => {
    const el = document.createElement('div');
    el.className = 'petal';
    el.textContent = p.emoji;
    el.style.cssText = `left:${p.left}%;font-size:${p.size}px;animation-duration:${p.duration}s;animation-delay:${p.delay}s;`;
    petalsEl.appendChild(el);
  });

  // Candles
  let candlesLit = true;
  function renderCandles() {
    const row = document.getElementById('candlesRow')!;
    row.innerHTML = '';
    for (let i = 0; i < 5; i++) {
      const c = document.createElement('div');
      c.className = 'candle' + (candlesLit ? ' lit' : '');
      c.innerHTML = candlesLit
        ? `<div class="flame">🔥</div><div class="wax"></div>`
        : `<div class="wax"></div>`;
      row.appendChild(c);
    }
  }
  renderCandles();

  function spawnConfetti() {
    const container = document.getElementById('confetti')!;
    const emojis = ["🎉","🎊","✨","💜","🩷","🌸","⭐"];
    for (let i = 0; i < 32; i++) {
      const el = document.createElement('div');
      el.className = 'confetti-piece';
      el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
      const sx = 35 + Math.random() * 30;
      const sy = 30 + Math.random() * 10;
      const vx = (Math.random() - .5) * 280;
      const vy = -(80 + Math.random() * 130);
      el.style.cssText = `left:${sx}%;top:${sy}%;`;
      container.appendChild(el);
      el.animate([
        { transform: 'translate(0,0) rotate(0deg)', opacity: '1' },
        { transform: `translate(${vx}px,${vy}px) rotate(540deg)`, opacity: '0' },
      ], { duration: 2000, easing: 'ease-out', fill: 'forwards' });
      setTimeout(() => el.remove(), 2200);
    }
  }

  // expose to onclick
  (window as any).blowCandles = function () {
    if (!candlesLit) return;
    candlesLit = false;
    renderCandles();
    const btn = document.getElementById('blowBtn')!;
    btn.textContent = '✨ Yeay! Selamat ulang tahun! 🎉';
    btn.classList.add('blown');
    spawnConfetti();
    setTimeout(() => {
      candlesLit = true;
      renderCandles();
      btn.textContent = '🎂 Tiup lilinnya, Ibu Bos!';
      btn.classList.remove('blown');
    }, 5000);
  };

  // Messages
  let msgIdx = 0;
  function renderMsg() {
    const inner = document.getElementById('msgInner')!;
    inner.style.animation = 'none';
    inner.offsetHeight; // reflow
    inner.style.animation = 'slideIn .4s ease both';
    document.getElementById('msgFrom')!.textContent = '💌 Dari ' + MESSAGES[msgIdx].from;
    document.getElementById('msgText')!.textContent = '"' + MESSAGES[msgIdx].msg + '"';
    const dots = document.getElementById('dots')!;
    dots.innerHTML = '';
    MESSAGES.forEach((_, i) => {
      const d = document.createElement('div');
      d.className = 'dot' + (i === msgIdx ? ' active' : '');
      d.onclick = () => { msgIdx = i; renderMsg(); };
      dots.appendChild(d);
    });
  }
  renderMsg();
  setInterval(() => { msgIdx = (msgIdx + 1) % MESSAGES.length; renderMsg(); }, 4500);

  // Wishes
  const grid = document.getElementById('wishesGrid')!;
  WISHES.forEach((w, i) => {
    const card = document.createElement('div');
    card.className = 'wish-card';
    card.innerHTML = `<span class="wish-icon">${w.icon}</span><span class="wish-text">${w.text}</span>`;
    grid.appendChild(card);
    setTimeout(() => {
      card.style.animation = 'wishIn .5s ease forwards';
    }, 600 + i * 220);
  });
</script>